<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  macOS launchd: HİBRİT pipeline'ı her gün 09:25'te çalıştırır.
  Kurulum:
    cp com.haberler.hibrit.plist ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/com.haberler.hibrit.plist
  Durdurma:
    launchctl unload ~/Library/LaunchAgents/com.haberler.hibrit.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.haberler.hibrit</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/sh</string>
        <string>/Users/apple/Haberler/n8n/scheduler/run-hibrit.sh</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key><integer>9</integer>
        <key>Minute</key><integer>25</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/apple/Haberler/n8n/scheduler/hibrit.launchd.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/apple/Haberler/n8n/scheduler/hibrit.launchd.err.log</string>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
